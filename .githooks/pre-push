#!/bin/sh

if [ "$FC_SKIP_PREPUSH_VALIDATE" = "1" ]; then
  echo "[pre-push] Skip validate:prepush (already validated in release flow)."
  exit 0
fi

echo "[pre-push] Running full quality checks..."
npm run validate:prepush
status=$?

if [ $status -ne 0 ]; then
  echo "[pre-push] Failed: push blocked because validation did not pass."
  exit $status
fi

echo "[pre-push] Passed."
